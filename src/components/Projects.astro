---
import Button from "./Button.astro";

interface Project {
  title: string;
  description: string;
  image?: string;
  previewUrl: string;
  repoUrl: string;
  tag?: string;
  featured?: boolean;
}

interface Props {
  title: string;
  subtitle?: string;
  items: Project[];
}

const { title, subtitle, items } = Astro.props;

const githubIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>`;
---

<section class="sy-projects" id="proyectos">
  <div class="u-container">
    <h2 class="u-heading title" data-sy-reveal="words">{title}</h2>
    {subtitle && <p class="u-text subtitle" data-sy-reveal="lines">{subtitle}</p>}

    <div class="projects">
      {
        items.map((project) => (
          <div class:list={["project", project.featured && "project--featured"]}>
            <div class="project-inner">
              {project.tag && (
                <span class="project-tag u-text" data-sy-reveal="words">
                  {project.tag}
                </span>
              )}
              <h3 class="u-heading project-title" data-sy-reveal="words">
                {project.title}
              </h3>
              <p class="u-text project-desc" data-sy-reveal="lines">
                {project.description}
              </p>
              <div class="project-actions">
                <Button
                  title="Ver preview"
                  url={project.previewUrl}
                  target="_blank"
                  color={project.featured ? "primary" : "primary-alt"}
                  arrow
                  revealable={false}
                />
                <a
                  class="repo-link u-text"
                  href={project.repoUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  set:html={githubIcon + " GitHub"}
                />
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  @keyframes project-border {
    from { transform: rotate(0deg); }
    to   { transform: rotate(365deg); }
  }

  .sy-projects {
    margin: 2rem 0;
    position: relative;
    z-index: 2;
  }

  .title {
    --fs: 3rem;
    text-align: center;
    text-transform: uppercase;
    margin-bottom: 0.1em;
  }

  .subtitle {
    --fs: var(--font-size-md);
    color: var(--color-text-alt);
    max-width: 32em;
    text-align: center;
    margin: 0 auto 2em;
  }

  /* ── Grid de tarjetas ── */
  .projects {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 2rem;

    @media (--mq-tablet-sm) {
      flex-direction: column;
      align-items: center;
    }
  }

  /* ── Tarjeta base ── */
  .project {
    border-radius: 1rem;
    max-width: 22rem;
    width: 100%;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
    position: relative;
    padding: 2px;
    background: #1a1a1a;
    overflow: hidden;
  }

  /* ── Tarjeta destacada: borde animado ── */
  .project--featured {
    background: transparent;

    &::after {
      background: linear-gradient(135deg, #5a1d6b 0%, #9b4dca 50%, #f5a623 100%);
      border-radius: 1rem;
      content: "";
      height: 200%;
      width: 200%;
      position: absolute;
      top: -50%;
      left: -50%;
      z-index: -1;
      animation: project-border 5s linear infinite;
    }
  }

  /* ── Interior ── */
  .project-inner {
    background: #141414;
    border-radius: 0.9rem;
    padding: 2rem;
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .project-tag {
    --fs: 0.62rem;
    --fw: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(155, 77, 202, 0.9);
  }

  .project-title {
    --fs: 1.75rem;
    --fw: 600;
    --lh: 1.15;
    margin: 0;
  }

  .project-desc {
    --fs: var(--font-size-sm);
    color: var(--color-text-alt);
    line-height: 1.65;
    flex: 1;
    margin: 0.5rem 0 1rem;
  }

  /* ── Botones ── */
  .project-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: auto;
  }

  .repo-link {
    --fs: var(--font-size-xs);
    --fw: 600;
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    color: var(--color-text-alt);
    text-decoration: none;
    letter-spacing: 0.03em;
    padding: 0.5em 1.1em;
    border-radius: 100px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    transition:
      color 0.3s ease,
      border-color 0.3s ease,
      background 0.3s ease;

    &:hover {
      color: #fafafa;
      border-color: rgba(245, 166, 35, 0.45);
      background: rgba(245, 166, 35, 0.07);
    }

    svg {
      flex-shrink: 0;
    }
  }
</style>
